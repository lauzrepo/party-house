# Frontend Environment Variables
# Copy this file to frontend/.env and fill in your actual values

# ============================================
# API Configuration
# ============================================
# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# WebSocket URL (if using real-time features)
# VITE_WS_URL=ws://localhost:5000

# ============================================
# Helcim Configuration
# ============================================
# Helcim public token for client-side tokenization
# Get this from your Helcim dashboard
VITE_HELCIM_TOKEN=your-helcim-public-token

# Helcim.js library URL
VITE_HELCIM_JS_URL=https://js.helcim.com/v2/helcim.js

# ============================================
# Application Configuration
# ============================================
# Application name
VITE_APP_NAME=Payment Portal

# Application version
VITE_APP_VERSION=1.0.0

# Environment (development, staging, production)
VITE_ENVIRONMENT=development

# ============================================
# Feature Flags
# ============================================
# Enable/disable features
VITE_ENABLE_SUBSCRIPTIONS=true
VITE_ENABLE_INVOICES=true
VITE_ENABLE_PAYMENT_METHODS=true
VITE_ENABLE_GDPR_FEATURES=true

# Enable debug mode (shows console logs)
VITE_DEBUG_MODE=true

# Enable test mode (uses Helcim test cards)
VITE_TEST_MODE=true

# ============================================
# Payment Configuration
# ============================================
# Supported currencies
VITE_SUPPORTED_CURRENCIES=USD,CAD,EUR,GBP

# Default currency
VITE_DEFAULT_CURRENCY=USD

# Minimum payment amount (in dollars/main unit)
VITE_MIN_PAYMENT_AMOUNT=1.00

# Maximum payment amount (in dollars/main unit)
VITE_MAX_PAYMENT_AMOUNT=100000.00

# ============================================
# UI Configuration
# ============================================
# Theme mode (light, dark, auto)
VITE_DEFAULT_THEME=light

# Primary color (hex)
VITE_PRIMARY_COLOR=#1976d2

# Secondary color (hex)
VITE_SECONDARY_COLOR=#dc004e

# Items per page for pagination
VITE_ITEMS_PER_PAGE=10

# ============================================
# Analytics (Optional)
# ============================================
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ============================================
# Error Tracking (Optional)
# ============================================
# Sentry DSN for frontend error tracking
# VITE_SENTRY_DSN=your-sentry-dsn
# VITE_SENTRY_ENVIRONMENT=development

# ============================================
# External Services
# ============================================
# reCAPTCHA (for bot protection)
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Intercom (for customer support chat)
# VITE_INTERCOM_APP_ID=your-intercom-app-id

# ============================================
# Cookie Banner
# ============================================
VITE_ENABLE_COOKIE_BANNER=true
VITE_COOKIE_DOMAIN=localhost

# ============================================
# Session Configuration
# ============================================
# Session timeout (in milliseconds)
VITE_SESSION_TIMEOUT=900000

# Token refresh interval (in milliseconds)
VITE_TOKEN_REFRESH_INTERVAL=840000

# ============================================
# API Timeouts
# ============================================
# Default API timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# Payment API timeout (longer for processing)
VITE_PAYMENT_API_TIMEOUT=60000

# ============================================
# Localization
# ============================================
# Default language
VITE_DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=en,es,fr

# ============================================
# Social Media Links (Optional)
# ============================================
# VITE_FACEBOOK_URL=https://facebook.com/yourpage
# VITE_TWITTER_URL=https://twitter.com/yourhandle
# VITE_LINKEDIN_URL=https://linkedin.com/company/yourcompany

# ============================================
# Support & Contact
# ============================================
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_SUPPORT_PHONE=+1-555-123-4567

# ============================================
# Legal Documents
# ============================================
VITE_TERMS_URL=/terms-of-service
VITE_PRIVACY_URL=/privacy-policy
VITE_REFUND_URL=/refund-policy

# ============================================
# Development Tools
# ============================================
# Enable React DevTools
VITE_ENABLE_DEVTOOLS=true

# Enable Redux DevTools (if using Redux)
# VITE_ENABLE_REDUX_DEVTOOLS=true

# Mock API responses (for development without backend)
# VITE_MOCK_API=false

# ============================================
# Build Configuration
# ============================================
# Base path for deployment (if not at root)
# VITE_BASE_PATH=/

# Asset optimization
VITE_OPTIMIZE_IMAGES=true
VITE_MINIFY_CSS=true
VITE_MINIFY_JS=true

# ============================================
# SEO Configuration
# ============================================
VITE_META_TITLE=Payment Portal - Secure Online Payments
VITE_META_DESCRIPTION=Process secure payments, manage subscriptions, and view invoices
VITE_META_KEYWORDS=payment portal, secure payments, subscriptions, invoices

# Open Graph
VITE_OG_IMAGE=/og-image.png
VITE_OG_URL=https://yourdomain.com

# ============================================
# Testing (Test Environment Only)
# ============================================
# Helcim test cards
# Visa: 4111 1111 1111 1111
# Mastercard: 5454 5454 5454 5454
# Any future expiry date, any 3-digit CVV

# Test user credentials (for automated tests)
# VITE_TEST_EMAIL=test@example.com
# VITE_TEST_PASSWORD=TestPassword123!

# ============================================
# Notes
# ============================================
# 1. All Vite env vars must be prefixed with VITE_
# 2. NEVER commit sensitive tokens to version control
# 3. Use different values for development, staging, and production
# 4. Frontend env vars are exposed to the client - don't put secrets here
# 5. Use .env.local for local overrides (not committed to git)
# 6. Restart dev server after changing environment variables
